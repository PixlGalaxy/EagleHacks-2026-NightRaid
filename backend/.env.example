################################################################################
# NightRaid Banking Analysis Backend - Environment Configuration
# This file contains sensitive configuration and should NEVER be committed to git
################################################################################

# ============================================================================
# Flask Configuration
# ============================================================================
# Available options: development, production
FLASK_ENV=production

# Enable/disable debug mode (True/False) Case Sensitive
FLASK_DEBUG=False

# Server port (default: 5000)
PORT=5000

# ============================================================================
# Ollama Configuration
# ============================================================================
# Ollama server base URL
OLLAMA_BASE_URL=http://localhost:11434

# Model name to use for financial analysis
OLLAMA_MODEL=gpt-oss:20b

# API key for Ollama
# Leave empty if not needed
OLLAMA_API_KEY=

# Request timeout in seconds
OLLAMA_TIMEOUT=120

# ============================================================================
# File Upload Configuration
# ============================================================================
# Maximum file size in bytes
# Default: 10485760 (10MB)
MAX_FILE_SIZE=10485760

# ============================================================================
# CORS Configuration
# ============================================================================
# Comma-separated list of allowed origin URLs | Change on production -Pixl
CORS_ORIGINS=*

# ============================================================================
# API Configuration
# ============================================================================
# API version for endpoint versioning and documentation
API_VERSION=v1
